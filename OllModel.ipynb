INDEX_TYPE = {'.svg'}
class_name_map = {}

for class_folder in dataset_dir.iterdir():
    if class_folder.is_dir():
        class_name_en = class_folder.name
        try:
            class_name_ru = tr.translate_text(class_name_en, from_language='en', to_language='ru')
        except:
            class_name_ru = class_name_en
        class_name_map[class_name_en] = class_name_ru

        for file_name in class_folder.iterdir():
            if file_name.suffix.lower() in INDEX_TYPE:
                file_name.unlink(missing_ok=True)
            elif file_name.suffix.lower() != ".jpg":
                img = Image.open(file_name).convert("RGB")
                img.save(file_name.with_suffix(".jpg"), "JPEG")
                file_name.unlink()
        print(f"{class_name_en:15} → {class_name_ru:15} : {count_files_in_folder(class_folder)} файлов")
