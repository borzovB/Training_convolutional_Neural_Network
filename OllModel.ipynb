comparison_table.append(["CNN3 (K-Fold Mean)", np.mean(fold_results)])


# DataFrame
df_final = pd.DataFrame(comparison_table, columns=["Model", "Accuracy"])

df_final = df_final.sort_values(by="Accuracy", ascending=False).reset_index(drop=True)

print("Финальное сравнение моделей:")
display(df_final)

# График сравнения моделей

plt.figure(figsize=(8,5))

plt.bar(df_final["Model"], df_final["Accuracy"])

plt.xticks(rotation=45)
plt.ylabel("Accuracy")
plt.title("Model Comparison")

plt.show()
