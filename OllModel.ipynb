# Модель
resnet50 = models.resnet50(weights=models.ResNet50_Weights.IMAGENET1K_V1)
for param in resnet50.parameters(): param.requires_grad = False
num_features = resnet50.fc.in_features
resnet50.fc = nn.Sequential(
    nn.Linear(num_features, 256),
    nn.ReLU(),
    nn.Dropout(0.5),
    nn.Linear(256, num_classes)
)
resnet50 = resnet50.to(device)

criterion_tl = nn.CrossEntropyLoss()
optimizer_tl = torch.optim.Adam(resnet50.fc.parameters(), lr=1e-3)

# Обучение
epochs = 5
# Списки для хранения метрик по эпохам
train_losses_tl_list = []
train_accs_tl_list = []
val_accs_tl_list   = []

for epoch in range(epochs):
    resnet50.train()
    running_loss = 0.0
    correct, total = 0, 0
    for images, labels in train_loader_tl:
        images, labels = images.to(device), labels.to(device)
        optimizer_tl.zero_grad()
        outputs = resnet50(images)
        loss = criterion_tl(outputs, labels)
        loss.backward()
        optimizer_tl.step()
        running_loss += loss.item() * images.size(0)
        preds = torch.argmax(outputs,1)
        correct += (preds==labels).sum().item()
        total += labels.size(0)

    train_loss = running_loss / total
    train_acc = correct / total

    # Валидация
    resnet50.eval()
    val_correct, val_total = 0, 0
    with torch.no_grad():
        for images, labels in val_loader_tl:
            images, labels = images.to(device), labels.to(device)
            outputs = resnet50(images)
            preds = torch.argmax(outputs,1)
            val_correct += (preds==labels).sum().item()
            val_total += labels.size(0)
    val_acc = val_correct / val_total

    # Сохраняем метрики по эпохам
    train_losses_tl_list.append(train_loss)
    train_accs_tl_list.append(train_acc)
    val_accs_tl_list.append(val_acc)

    print(f"Epoch {epoch+1}/{epochs} - Loss: {train_loss:.4f} - Train Acc: {train_acc:.4f} - Val Acc: {val_acc:.4f}")
