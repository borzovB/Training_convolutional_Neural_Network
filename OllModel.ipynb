import random

# --- Пример MixUp ---
def show_mixup_examples(dataset, n_examples=5, alpha=0.4):
    print("Примеры MixUp:")

    for i in range(n_examples):

        idx1 = random.randint(0, len(dataset)-1)
        idx2 = random.randint(0, len(dataset)-1)

        x1, y1 = dataset[idx1]
        x2, y2 = dataset[idx2]

        x = torch.stack([x1, x2])   # batch = 2
        y = torch.tensor([y1, y2])

        x_mix, y_a, y_b, lam = mixup_data(x, y, alpha)

        x_mix_img = x_mix[0].permute(1,2,0).numpy()
        x_mix_img = np.clip(x_mix_img,0,1)

        plt.imshow(x_mix_img)
        plt.title(f"λ={lam:.2f} | {class_names[y_a[0]]} + {class_names[y_b[0]]}")
        plt.axis('off')
        plt.show()

show_mixup_examples(train_dataset)

